generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OFFICER)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @db.Timestamptz(6)
}

model SystemLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event      String
  details    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_systemlog_created_at")
  @@index([event], map: "idx_systemlog_event")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cameras {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  location         String
  lat              Float
  lng              Float
  status           String?             @default("ACTIVE")
  stream_url       String?
  created_at       DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?           @default(now()) @db.Timestamptz(6)
  violations       violations[]
  vehicle_sightings vehicle_sightings[]
  traffic_metrics  traffic_metrics[]
}

/// Jejak setiap kendaraan yang tertangkap kamera — untuk Vehicle Tracking lintas CCTV.
/// Dikirim oleh AI Engine setiap kali berhasil membaca plat nomor (cooldown 10 detik/plat/kamera).
model vehicle_sightings {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  license_plate String
  camera_id     String?   @db.Uuid
  vehicle_type  String?   @default("CAR")
  confidence    Float     @default(0.0)
  speed_kmh     Float?
  direction     String?
  snapshot_url  String?
  is_flagged    Boolean   @default(false)
  flag_reason   String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  cameras       cameras?  @relation(fields: [camera_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([license_plate, created_at(sort: Desc)], map: "idx_sightings_plate_time")
  @@index([camera_id, created_at(sort: Desc)],    map: "idx_sightings_camera_time")
  @@index([created_at(sort: Desc)],               map: "idx_sightings_created")
}

/// Volume lalu lintas per kamera per jam — untuk Traffic Forecast, ERP, dan Executive Dashboard.
/// Dikirim oleh AI Engine setiap 60 detik sebagai agregat jumlah kendaraan dalam frame.
model traffic_metrics {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camera_id     String?   @db.Uuid
  recorded_at   DateTime  @default(now()) @db.Timestamptz(6)
  vehicle_count Int       @default(0)
  avg_speed_kmh Float?
  congestion    Float?    /// 0.0 (lancar) – 1.0 (macet total)
  cameras       cameras?  @relation(fields: [camera_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([camera_id, recorded_at(sort: Desc)], map: "idx_traffic_camera_time")
  @@index([recorded_at(sort: Desc)],            map: "idx_traffic_recorded")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model violations {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camera_id       String?   @db.Uuid
  type            String
  license_plate   String
  vehicle_type    String?   @default("CAR")
  confidence      Float
  duration        Int?
  evidence_url    String?
  location        String
  lat             Float
  lng             Float
  status          String?   @default("PENDING")
  timestamp       DateTime? @default(now()) @db.Timestamptz(6)
  processed_at    DateTime? @db.Timestamptz(6)
  etle_ref        String?
  screenshot_sent Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  cameras         cameras?  @relation(fields: [camera_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum Role {
  ADMIN
  OFFICER
  VIEWER
}

enum CameraStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ViolationType {
  ILLEGAL_PARKING
  BUSWAY_VIOLATION
  BICYCLE_LANE_VIOLATION
  BUS_STOP_VIOLATION
  WRONG_LANE
}

enum VehicleType {
  CAR
  MOTORCYCLE
  BUS
  TRUCK
  OTHER
}

enum ViolationStatus {
  PENDING
  VERIFIED
  EXPORTED
  DISMISSED
}

model citizen_reports {
  id           String    @id
  status       String    @default("AI_REVIEW")
  violation_type String
  location     String
  description  String
  reporter     String    @default("Anonim")
  ai_confidence Float    @default(0)
  ai_decision  String?
  evidence_url String?
  lat          Float?
  lng          Float?
  source       String    @default("JAKI")
  submitted_at DateTime  @default(now()) @db.Timestamptz(6)
  processed_at DateTime? @db.Timestamptz(6)
  processed_by String?
}

model app_settings {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  updated_by String?
}
